{
  "expo": {
    "name": "resconi-GMap",
    "slug": "resconi-gmap",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icons/resconi.png",
    "scheme": "resconigmap",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.resconi.geomap",
      "supportsTablet": true,
      "icon": "./assets/icons/resconi.png"
    },
    "android": {
      "package": "com.resconi.geomap",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/icons/appCare.png",
        "backgroundImage": "./assets/icons/appCare.png",
        "monochromeImage": "./assets/icons/appCare.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "single",
      "bundler": "metro",
      "favicon": "./assets/icons/resconi.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/resconi.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-image",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": false,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "445f616c-aa2c-4e5f-a340-20a41fd85f71"
      }
    },
    "owner": "icedilo45"
  }
}
